@model ProyectoPAE.Models.ReporteEstudianteViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Reporte Académico - @Model.NombreCompleto</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
            .header-section { border-bottom: 2px solid #004a99; padding-bottom: 10px; margin-bottom: 20px; }
            .logo { width: 120px; height: auto; }
            .table-notas {
                width: 100%;
                border-collapse: collapse;
                margin-top: 25px;
                font-family: Arial, sans-serif;
            }

            .table-notas th, .table-notas td {
                border: 1px solid #004a99; /* Bordes azules para que resalten */
                padding: 10px;
                text-align: center;
                font-size: 12px;
            }

            .table-notas thead th {
                background-color: #004a99; /* Color azul institucional */
                color: white;
                text-transform: uppercase;
            }

            .table-notas tbody tr:nth-child(even) {
                background-color: #f2f2f2; /* Color gris suave para filas alternas */
            }

            .definitiva {
                font-weight: bold;
                background-color: #e8f0fe;
            }
    </style>
</head>
<body class="p-4">
    <div class="header-section d-flex justify-content-between align-items-center">
        <div>
            <img src="@(Context.Request.Scheme + "://" + Context.Request.Host + "/images/logo.png")" class="logo" style="width:150px;" />
        </div>
        <div class="text-end">
            <h2 class="mb-0">BOLETÍN DE CALIFICACIONES</h2>
            <p class="text-muted">Portal de Autogestión Educativa (PAE)</p>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-6">
            <p><strong>Estudiante:</strong> @Model.NombreCompleto</p>
            <p><strong>Código:</strong> @Model.Codigo</p>
        </div>
        <div class="col-6 text-end">
            <p><strong>Fecha:</strong> @DateTime.Now.ToString("dd/MM/yyyy")</p>
        </div>
    </div>

    <table class="table table-bordered table-notas text-center">
        <thead>
            <tr>
                <th class="text-start">Asignatura</th>
                <th>P1</th>
                <th>P2</th>
                <th>P3</th>
                <th>P4</th>
                <th>Definitiva</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.NotasPorMateria != null && Model.NotasPorMateria.Any())
            {
                foreach (var fila in Model.NotasPorMateria)
                {
                    <tr>
                        <td class="text-start">@fila.NombreMateria</td>
                        <td>@fila.Periodo1.ToString("N1")</td>
                        <td>@fila.Periodo2.ToString("N1")</td>
                        <td>@fila.Periodo3.ToString("N1")</td>
                        <td>@fila.Periodo4.ToString("N1")</td>
                        <td class="fw-bold @(fila.Definitiva < 3 ? "text-danger" : "text-success")">
                            @fila.Definitiva.ToString("N1")
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center">No hay calificaciones registradas para este estudiante.</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-5 pt-5">
        <div class="row">
            <div class="col-4 text-center">
                <hr>
                <p>Firma Coordinación</p>
            </div>
        </div>
    </div>
</body>
</html>