<script>
    function ocultarTodo() {
        const subs = [
            'admin-main', 'admin-matricula', 'admin-usuarios', 'admin-certificados', 'admin-notificaciones', 'admin-asignacion', 'admin-reportes',
            'docente-main', 'docente-planilla', 'docente-asistencia', 'docente-observaciones',
            'estudiante-main',
            'estudiante-horario',
            'estudiante-calificaciones',
            'estudiante-actividades',
            'estudiante-cursosextra'
        ];

        const panelesPrincipales = [
            'panel-admin', 'panel-docente', 'panel-estudiante', 'panel-acudiente'
        ];

        subs.forEach(id => {
            const el = document.getElementById(id);
            if (el) el.classList.add('d-none');
        });

        panelesPrincipales.forEach(id => {
            const p = document.getElementById(id);
            if (p) p.classList.add('d-none');
        });
    }

    // Funciones de navegación Admin
    function verMatricula() { ocultarTodo(); mostrarAdminSub('admin-matricula'); }
    function verUsuarios() { ocultarTodo(); mostrarAdminSub('admin-usuarios'); }
    function verCertificados() { ocultarTodo(); mostrarAdminSub('admin-certificados'); }
    function verNotificaciones() { ocultarTodo(); mostrarAdminSub('admin-notificaciones'); }
    function verAsignacion() { ocultarTodo(); mostrarAdminSub('admin-asignacion'); }
    function verReportes() { ocultarTodo(); mostrarAdminSub('admin-reportes'); }

    function mostrarAdminSub(id) {
        ocultarTodo();
        document.getElementById('panel-admin').classList.remove('d-none');
        const subSeccion = document.getElementById(id);
        if (subSeccion) {
            subSeccion.classList.remove('d-none');
        }
    }

    function volverAdmin() {
        ocultarTodo();
        document.getElementById('panel-admin').classList.remove('d-none');
        document.getElementById('admin-main').classList.remove('d-none'); 
    }

    document.addEventListener("DOMContentLoaded", function () {
        const rolDesdeSesion = document.getElementById('rolOculto').value;
        const selector = document.getElementById('roleSelector');

        if (selector && rolDesdeSesion) {
            // Sincronizamos el selector con el rol del login
            selector.value = rolDesdeSesion;

            // Ejecutamos la vista inicial
            switchRole();

            // Lógica de visibilidad del selector:
            if (rolDesdeSesion !== 'admin') {
                // Si NO es admin, escondemos el selector para que no "salte" de rol
                selector.style.display = 'none';
                // También puedes esconder el texto "Rol actual:" si quieres
                document.querySelector('.opacity-75').style.display = 'none';
            } else {
                // Si ES admin, nos aseguramos de que el selector sea visible
                selector.style.display = 'block';
                console.log("Modo Administrador: Selector de roles habilitado.");
            }
        }
    });

    function switchRole() {
        const role = document.getElementById('roleSelector').value.toLowerCase();
        console.log("Cambiando al rol: " + role);

        ocultarTodo();

        const panel = document.getElementById('panel-' + role);

        if (panel) {
            panel.classList.remove('d-none');

            // AGREGAR ESTO: Instrucciones para mostrar el contenido de cada rol
            if (role === 'admin') {
                const sub = document.getElementById('admin-main');
                if (sub) sub.classList.remove('d-none');
            }
            else if (role === 'docente') {
                const sub = document.getElementById('docente-main');
                if (sub) sub.classList.remove('d-none'); // Esto encenderá las tarjetas de Carlos Mendoza
            }
            else if (role === 'estudiante') {
                const sub = document.getElementById('estudiante-main');
                if (sub) sub.classList.remove('d-none'); // Esto encenderá las tarjetas de Laura Gómez
            }
            // El acudiente no necesita esto porque su panel no tiene sub-secciones aún
        } else {
            console.error("No se encontró un panel con el ID: panel-" + role);
        }
    }
    // Al cargar la página
    document.addEventListener("DOMContentLoaded", function () {
        switchRole();
    });

    // Navegación Docente
    function verPlanilla() {
        ocultarTodo();
        document.getElementById('panel-docente').classList.remove('d-none');
        document.getElementById('docente-planilla').classList.remove('d-none');
    }

    function verAsistencia() {
        ocultarTodo();
        document.getElementById('panel-docente').classList.remove('d-none');
        document.getElementById('docente-asistencia').classList.remove('d-none');
    }

    function volverDocente() {
        ocultarTodo();
        document.getElementById('panel-docente').classList.remove('d-none');
        document.getElementById('docente-main').classList.remove('d-none');
    }

    function verObservaciones() {
        ocultarTodo(); // Limpia la pantalla usando la lista 'subs'

        // Muestra el contenedor del docente
        const panel = document.getElementById('panel-docente');
        if (panel) panel.classList.remove('d-none');

        // Muestra específicamente el formulario del observador
        const subVista = document.getElementById('docente-observaciones');
        if (subVista) subVista.classList.remove('d-none');
    }

    // Navegación Estudiante
    function verHorario() {
        ocultarTodo();
        document.getElementById('panel-estudiante').classList.remove('d-none');
        document.getElementById('estudiante-horario').classList.remove('d-none');
    }

    function verCalificacionesEstudiante() {
        ocultarTodo();
        document.getElementById('panel-estudiante').classList.remove('d-none');
        document.getElementById('estudiante-calificaciones').classList.remove('d-none');
    }

    function verActividadesEstudiante() {
        ocultarTodo();

        document.getElementById('panel-estudiante').classList.remove('d-none');

        const divTareas = document.getElementById('estudiante-actividades');
        if (divTareas) {
            divTareas.classList.remove('d-none');
        }
    }

    function volverEstudiante() {
        switchRole();
        ocultarTodo();
        document.getElementById('panel-estudiante').classList.remove('d-none');
        document.getElementById('estudiante-main').classList.remove('d-none');
    }
    function verCursosExtra() {
        ocultarTodo();
        document.getElementById('panel-estudiante').classList.remove('d-none');
        document.getElementById('estudiante-cursosextra').classList.remove('d-none');
    }
</script>

<style>
    /* Clase para unificar el panel administrativo */
    .card-admin {
        border-left: 5px solid #fd7e14 !important; /* Línea naranja más marcada */
        transition: all 0.3s ease;
        cursor: pointer;
    }

        .card-admin:hover {
            background-color: #fffaf5; /* Un fondo naranja muy tenue al pasar el mouse */
            transform: scale(1.02);
            box-shadow: 0 10px 20px rgba(253, 126, 20, 0.1) !important;
        }
</style>

<style>
    /* 1. Quitamos el fondo azul de toda la tarjeta */
    .card-hover:hover {
        background-color: #ffffff !important; /* Se mantiene blanca */
        transform: translateY(-5px); /* Solo flota un poquito */
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        transition: all 0.3s ease;
    }

        /* 2. El botón es el que se ilumina con fuerza */
        .card-hover:hover .btn-outline-primary {
            background-color: #2980b9 !important;
            color: white !important;
            box-shadow: 0 4px 8px rgba(41, 128, 185, 0.3);
        }

    /* 3. Aseguramos que los textos no cambien de color bruscamente */
    .card-hover h6, .card-hover p, .card-hover i {
        transition: color 0.3s ease;
    }
</style>

<style>
    /* Estilo del botón: Sólido, Morado y Rectangular */
    .btn-estudiante-solido {
        background-color: #6f42c1 !important;
        color: white !important;
        border: none !important;
        border-radius: 4px !important; /* Mantiene la forma del botón negro */
        padding: 8px 16px;
        font-weight: 500;
        transition: all 0.3s ease;
    }

        /* Efecto al pasar el mouse sobre el botón */
        .btn-estudiante-solido:hover {
            background-color: #5a32a3 !important; /* Un morado un poco más oscuro */
            color: white !important;
            box-shadow: 0 4px 8px rgba(111, 66, 193, 0.3);
        }

    /* Mantenemos la tarjeta limpia y blanca */
    .card-estudiante-limpia {
        transition: all 0.3s ease;
        background-color: white !important;
    }

        .card-estudiante-limpia:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const selectHijo = document.getElementById("selectHijo");
        const btnVerNotas = document.getElementById("btnVerNotas");

        function actualizarEnlace() {
            const idHijo = selectHijo.value;
            // Construimos la ruta hacia Estudiante/MisNotas pasando el idEstudiante
            btnVerNotas.href = `/Estudiante/MisNotas?idEstudiante=${idHijo}`;
        }

        // Actualizar el enlace apenas cargue la página
        actualizarEnlace();

        // Actualizar el enlace cada vez que el padre cambie de hijo en el select
        selectHijo.addEventListener("change", actualizarEnlace);
    });
</script>