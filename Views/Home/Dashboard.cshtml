@{
    ViewData["Title"] = "Panel de Control Educativo";
    @using Microsoft.AspNetCore.Http
}

@{
    var nombre = Context.Session.GetString("NombreUsuario");
    var rol = Context.Session.GetString("UserRol");
}

<input type="hidden" id="rolOculto" value="@rol" />

<center><h2>Bienvenido/a, @nombre</h2></center>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const rolActivo = document.getElementById('rolOculto').value;

        // Usamos la función switchRole que ya existe,
        // pero le pasamos el valor automáticamente
        document.getElementById('roleSelector').value = rolActivo;
        switchRole();

        // OPCIONAL: Esconder el selector para que el usuario no cambie de rol
        document.getElementById('roleSelector').style.display = 'none';
    });
</script>

<div class="container-fluid fw-bold py-3 mb-4" style="background-color: #0d2a4a; color: white;">
    <div class="container d-flex justify-content-between align-items-center">
        <span><i class="bi bi-mortarboard-fill me-2"></i>SISTEMA DE GESTIÓN PAE</span>
        <div class="d-flex align-items-center gap-2">
            <small class="opacity-75">Rol actual:</small>
            <select id="roleSelector" class="form-select form-select-sm" onchange="switchRole()" style="width: auto;">
                <option value="admin">Administrador</option>
                <option value="docente">Docente</option>
                <option value="estudiante">Estudiante</option>
                <option value="acudiente">Acudiente</option>
            </select>
        </div>
    </div>
</div>

<div class="container pb-5">

    <div id="panel-admin" class="role-panel d-none">

        <div id="admin-main">
            <h2 class="mb-4" style="color: #e67e22;"><i class="bi bi-gear-fill me-2"></i>Gestión Administrativa</h2>

            <div class="row g-3 mb-3">
                <div class="col-md-3">
                    <div class="card p-3 shadow-sm border-0 h-100 text-center card-hover card-admin" onclick="verMatricula()" style="cursor: pointer;">
                        <i class="bi bi-clipboard-check fs-2 mb-2" style="color: #e67e22;"></i>
                        <h6>Matrículas</h6>
                    </div>
                </div>

                <div class="col-md-3">
                    <a href="/Admin/Usuarios" class="text-decoration-none h-100">
                        <div class="card p-3 shadow-sm border-0 h-100 text-center card-hover card-admin">
                            <i class="bi bi-people fs-2 mb-2" style="color: #e67e22;"></i>
                            <h6 class="text-dark">Usuarios y Roles</h6>
                        </div>
                    </a>
                </div>

                <div class="col-md-3">
                    <div class="card p-3 shadow-sm border-0 h-100 text-center card-hover card-admin" onclick="verCertificados()" style="cursor: pointer;">
                        <i class="bi bi-file-earmark-pdf fs-2 mb-2" style="color: #e67e22;"></i>
                        <h6>Certificados</h6>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="card p-3 shadow-sm border-0 h-100 text-center card-hover card-admin" onclick="verNotificaciones()" style="cursor: pointer;">
                        <i class="bi bi-megaphone fs-2 mb-2" style="color: #e67e22;"></i>
                        <h6>Notificaciones</h6>
                    </div>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-md-3">
                    <div class="card p-3 shadow-sm border-0 h-100 text-center card-hover card-admin" onclick="verAsignacion()" style="cursor: pointer;">
                        <i class="bi bi-diagram-3 fs-2 mb-2" style="color: #e67e22;"></i>
                        <h6>Asignación Académica</h6>
                    </div>
                </div>

                <div class="col-md-3">
                    <a href="@Url.Action("ListaEstudiantes", "Admin")" class="text-decoration-none">
                        <div class="card p-3 shadow-sm border-0 h-100 text-center card-hover card-admin">
                            <i class="bi bi-people-fill fs-2 mb-2" style="color: #e67e22;"></i>
                            <h6 class="text-dark">Gestionar Reportes</h6>
                        </div>
                    </a>
                </div>
            </div>
        </div>

        <div id="admin-matricula" class="d-none">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 style="color: #e67e22;"><i class="bi bi-clipboard-check me-2"></i>Matrículas</h3>
                <button class="btn btn-outline-secondary btn-sm" onclick="volverAdmin()">Volver</button>
            </div>
            <div class="card border-0 shadow-sm p-4">
                <h5>Registro de Estudiantes</h5>
                <hr>
                <div class="row g-3">
                    <div class="col-md-6"><input type="text" class="form-control" placeholder="Nombre completo"></div>
                    <div class="col-md-4"><select class="form-select"><option>Seleccionar Grado</option></select></div>
                    <div class="col-md-2"><button class="btn btn-warning text-white w-100">Guardar</button></div>
                </div>
            </div>
        </div>

        <div id="admin-usuarios" class="d-none">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 style="color: #e67e22;"><i class="bi bi-people-fill me-2"></i>Gestión de Usuarios</h3>
                <button class="btn btn-outline-secondary btn-sm" onclick="volverAdmin()">Volver</button>
            </div>
            <table class="table table-hover bg-white shadow-sm rounded">
                <thead class="table-light"><tr><th>Usuario</th><th>Rol</th><th>Acciones</th></tr></thead>
                <tbody><tr><td>admin_pae</td><td><span class="badge bg-warning">Admin</span></td><td><button class="btn btn-sm btn-light border">Editar</button></td></tr></tbody>
            </table>
        </div>

        <div id="admin-certificados" class="d-none">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 style="color: #e67e22;"><i class="bi bi-file-earmark-pdf-fill me-2"></i>Certificados</h3>
                <button class="btn btn-outline-secondary btn-sm" onclick="volverAdmin()">Volver</button>
            </div>
            <div class="card border-0 shadow-sm p-4">
                <input type="text" class="form-control mb-3" placeholder="Buscar por documento...">
                <div class="list-group">
                    <button class="list-group-item list-group-item-action d-flex justify-content-between">Certificado de Matrícula <i class="bi bi-download text-danger"></i></button>
                </div>
            </div>
        </div>

        <div id="admin-notificaciones" class="d-none">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 style="color: #e67e22;"><i class="bi bi-megaphone-fill me-2"></i>Notificaciones</h3>
                <button class="btn btn-outline-secondary btn-sm" onclick="volverAdmin()">Volver</button>
            </div>
            <div class="card border-0 shadow-sm p-4">
                <textarea class="form-control mb-3" rows="3" placeholder="Escriba el comunicado general..."></textarea>
                <button class="btn btn-warning text-white">Enviar a toda la institución</button>
            </div>
        </div>

        <div id="admin-asignacion" class="d-none">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 style="color: #e67e22;"><i class="bi bi-diagram-3-fill me-2"></i>Asignación Académica</h3>
                <button class="btn btn-outline-secondary btn-sm" onclick="volverAdmin()">Volver</button>
            </div>
            <div class="alert alert-info">Seleccione un docente para asignar sus materias y grupos correspondientes.</div>
        </div>

        <div id="admin-reportes" class="d-none">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 style="color: #e67e22;"><i class="bi bi-graph-up-arrow me-2"></i>Reportes Pro</h3>
                <button class="btn btn-outline-secondary btn-sm" onclick="volverAdmin()">Volver</button>
            </div>
            <div class="row g-3">
                <div class="col-md-6"><div class="card p-4 border-0 shadow-sm text-center"><h1 class="text-warning">92%</h1><p>Asistencia General</p></div></div>
                <div class="col-md-6"><div class="card p-4 border-0 shadow-sm text-center"><h1 class="text-warning">4.1</h1><p>Promedio Institucional</p></div></div>
            </div>
        </div>
    </div>

    <div id="panel-docente" class="role-panel d-none">
        <div id="docente-main">
            <h2 class="mb-4" style="color: #2980b9;"><i class="bi bi-person-badge-fill me-2"></i>Panel del Docente</h2>
            <div class="row">
                <div class="col-md-4 mb-4" onclick="location.href='/Docente/Planilla'" style="cursor: pointer;">
                    <div class="card p-4 text-center border-0 shadow-sm h-100 card-hover" style="border-top: 4px solid #2980b9 !important;">
                        <i class="bi bi-clipboard-check fs-2 mb-2" style="color: #2980b9;"></i>
                        <h5 class="text-dark">Planilla de Notas</h5>
                        <p class="small text-muted">Gestión de calificaciones y promedios.</p>
                        <button class="btn btn-sm btn-outline-primary mt-auto w-100">Ver Planilla</button>
                    </div>
                </div>

                <div class="col-md-4 mb-4" onclick="verAsistencia()" style="cursor: pointer;">
                    <div class="card p-4 text-center border-0 shadow-sm h-100 card-hover" style="border-top: 4px solid #2980b9 !important;">
                        <i class="bi bi-calendar-check fs-2 mb-2" style="color: #2980b9;"></i>
                        <h5>Asistencia</h5>
                        <p class="small text-muted">Toma de lista diaria.</p>
                        <button class="btn btn-sm btn-outline-primary mt-auto w-100">Ver asistencias</button>
                    </div>
                </div>

                <div class="col-md-4 mb-4" onclick="verObservaciones()" style="cursor: pointer;">
                    <div class="card p-4 text-center border-0 shadow-sm h-100 card-hover" style="border-top: 4px solid #2980b9 !important;">
                        <i class="bi bi-chat-dots fs-2 mb-2" style="color: #2980b9;"></i>
                        <h5>Observador</h5>
                        <p class="small text-muted">Seguimiento convivencial.</p>
                        <button class="btn btn-sm btn-outline-primary mt-auto w-100">Ver observaciones</button>
                    </div>
                </div>

                <div class="col-md-4 mb-4 mx-auto" onclick="location.href='/Docente/ReporteGrupal'" style="cursor: pointer;">
                    <div class="card p-4 text-center border-0 shadow-sm h-100 card-hover" style="border-top: 4px solid #2980b9 !important; min-width: 100%;">
                        <i class="bi bi-bar-chart-line fs-2 mb-2" style="color: #2980b9;"></i>
                        <h5 class="text-dark">Reportes Generales</h5>
                        <p class="small text-muted">Estadísticas y promedios grupales del curso.</p>
                        <button class="btn btn-sm btn-outline-primary mt-auto w-100">Ver Estadísticas</button>
                    </div>
                </div>
            </div>
        </div>

        <div id="docente-observaciones" class="d-none">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 style="color: #2980b9;"><i class="bi bi-eye me-2"></i>Observador del Alumno</h3>
                <button class="btn btn-outline-secondary btn-sm" onclick="volverDocente()">Volver</button>
            </div>

            <div class="card border-0 shadow-sm p-4 mb-4">
                <h5 class="mb-3 text-secondary">Crear Nueva Observación</h5>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label small fw-bold">Estudiante</label>
                        <select class="form-select">
                            <option>Ospina Juan Pablo</option>
                            <option>García María</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-bold">Tipo de Nota</label>
                        <select class="form-select">
                            <option class="text-success">Positiva / Mérito</option>
                            <option class="text-danger">Llamado de Atención</option>
                            <option class="text-warning">Seguimiento Académico</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-bold">Descripción del Evento</label>
                        <textarea class="form-control" rows="3" placeholder="Detalle lo sucedido..."></textarea>
                    </div>
                    <div class="col-12 text-end">
                        <button class="btn btn-primary"><i class="bi bi-save me-2"></i>Registrar en Observador</button>
                    </div>
                </div>
            </div>
        </div>

        <div id="docente-planilla" class="d-none">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 style="color: #2980b9;"><i class="bi bi-pencil-square me-2"></i>Planilla de Calificaciones</h3>
                <button class="btn btn-outline-secondary btn-sm" onclick="volverDocente()">Volver</button>
            </div>

            <div class="card border-0 shadow-sm p-4 mb-4">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Asignatura</label>
                        <select class="form-select"><option>Matemáticas - 6°A</option></select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Periodo</label>
                        <select class="form-select"><option>Primer Periodo</option></select>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm overflow-hidden">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-3">Estudiante</th>
                            <th class="text-center">Tarea 1 (20%)</th>
                            <th class="text-center">Examen (40%)</th>
                            <th class="text-center">Actitudinal (20%)</th>
                            <th class="text-center">Definitiva</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="ps-3 fw-bold">Ospina Juan Pablo</td>
                            <td><input type="number" class="form-control form-control-sm text-center" value="4.5" step="0.1"></td>
                            <td><input type="number" class="form-control form-control-sm text-center" value="3.8" step="0.1"></td>
                            <td><input type="number" class="form-control form-control-sm text-center" value="5.0" step="0.1"></td>
                            <td class="text-center"><span class="badge bg-success fs-6">4.2</span></td>
                        </tr>
                        <tr>
                            <td class="ps-3 fw-bold">García María</td>
                            <td><input type="number" class="form-control form-control-sm text-center" value="3.0" step="0.1"></td>
                            <td><input type="number" class="form-control form-control-sm text-center" value="2.5" step="0.1"></td>
                            <td><input type="number" class="form-control form-control-sm text-center" value="4.0" step="0.1"></td>
                            <td class="text-center"><span class="badge bg-danger fs-6">2.9</span></td>
                        </tr>
                    </tbody>
                </table>
                <div class="p-3 bg-light text-end">
                    <button class="btn btn-primary"><i class="bi bi-save me-2"></i>Guardar Calificaciones</button>
                </div>
            </div>
        </div>
        <div id="docente-asistencia" class="d-none">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 style="color: #2980b9;"><i class="bi bi-calendar-check me-2"></i>Control de Asistencia</h3>
                <button class="btn btn-outline-secondary btn-sm" onclick="volverDocente()">Volver</button>
            </div>

            <div class="card border-0 shadow-sm p-4 mb-4">
                <div class="row g-3 align-items-center">
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Fecha</label>
                        <input type="date" class="form-control" value="2024-03-15">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Grupo</label>
                        <select class="form-select"><option>6° Grado - A</option></select>
                    </div>
                    <div class="col-md-4 text-end">
                        <button class="btn btn-success"><i class="bi bi-check-all me-2"></i>Marcar todos como Presente</button>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm overflow-hidden">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Estudiante</th>
                            <th class="text-center">Estado</th>
                            <th>Observación</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="ps-3">Ospina Juan Pablo</td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm" role="group">
                                    <input type="radio" class="btn-check" name="ast1" id="p1" checked>
                                    <label class="btn btn-outline-success" for="p1">P</label>
                                    <input type="radio" class="btn-check" name="ast1" id="f1">
                                    <label class="btn btn-outline-danger" for="f1">F</label>
                                    <input type="radio" class="btn-check" name="ast1" id="r1">
                                    <label class="btn btn-outline-warning" for="r1">R</label>
                                </div>
                            </td>
                            <td><input type="text" class="form-control form-control-sm" placeholder="Opcional..."></td>
                        </tr>
                        <tr>
                            <td class="ps-3">García María</td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm" role="group">
                                    <input type="radio" class="btn-check" name="ast2" id="p2" checked>
                                    <label class="btn btn-outline-success" for="p2">P</label>
                                    <input type="radio" class="btn-check" name="ast2" id="f2">
                                    <label class="btn btn-outline-danger" for="f2">F</label>
                                    <input type="radio" class="btn-check" name="ast2" id="r2">
                                    <label class="btn btn-outline-warning" for="r2">R</label>
                                </div>
                            </td>
                            <td><input type="text" class="form-control form-control-sm" placeholder="Opcional..."></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div id="panel-acudiente" class="role-panel d-none">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 style="color: #27ae60;"><i class="bi bi-person-heart me-2"></i>Panel de Padres</h2>

            <div class="d-flex align-items-center bg-success text-white px-3 py-1 rounded-pill shadow-sm">
                <span class="small me-2 fw-bold">Hijo(a):</span>
                <select id="selectHijo" class="form-select form-select-sm border-0 bg-transparent text-white p-0 fw-bold" style="box-shadow: none; cursor: pointer; min-width: 150px;">
                    @if (ViewBag.ListaHijos != null)
                    {
                        foreach (var hijo in ViewBag.ListaHijos)
                        {
                            <option value="@hijo.ID_Usuario" class="text-dark">
                                @hijo.NOMBRES @hijo.APELLIDOS
                            </option>
                        }
                    }
                    else
                    {
                        <option class="text-dark">Cargando estudiantes...</option>
                    }
                </select>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-4">
                <div class="card p-4 text-center border-0 shadow-sm card-hover" style="border-top: 4px solid #27ae60 !important;">
                    <i class="bi bi-journal-text fs-2 mb-2" style="color: #27ae60;"></i>
                    <h5>Ver Calificaciones</h5>
                    <p class="small text-muted">Promedio actual: <strong class="text-success">@ViewBag.PromedioRapido</strong></p>
                    <a id="btnVerNotas" href="#" class="btn btn-sm btn-outline-success">
                        Ver Reporte
                    </a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card p-4 text-center border-0 shadow-sm card-hover" style="border-top: 4px solid #27ae60 !important;">
                    <i class="bi bi-calendar-check fs-2 mb-2" style="color: #27ae60;"></i>
                    <h5>Asistencia</h5>
                    <p class="small text-muted">Fallas registradas: <strong class="text-danger">@ViewBag.FallasRapidas</strong></p>
                    <button class="btn btn-sm btn-outline-success" data-bs-toggle="modal" data-bs-target="#modalAsistencia">
                        Ver Detalle
                    </button>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card p-4 text-center border-0 shadow-sm card-hover" style="border-top: 4px solid #27ae60 !important;">
                    <i class="bi bi-chat-left-dots fs-2 mb-2" style="color: #27ae60;"></i>
                    <h5>Citaciones</h5>
                    <p class="small text-muted">Mensajes directos de los docentes.</p>
                    <button class="btn btn-sm btn-outline-success" data-bs-toggle="modal" data-bs-target="#modalCitaciones">
                        Ir a Mensajes
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div id="panel-estudiante" class="role-panel d-none">
        <div id="estudiante-main">
            <h2 class="mb-4" style="color: #6f42c1;"><i class="bi bi-mortarboard-fill me-2"></i>Mi Panel Académico</h2>

            <div class="row">
                <div class="col-md-4 mb-4">
                    <div class="card p-4 text-center border-0 shadow-sm h-100 card-estudiante-limpia"
                         style="border-top: 4px solid #6f42c1 !important; cursor: pointer;"
                         onclick="verHorario()">
                        <i class="bi bi-calendar3 fs-2 mb-2" style="color: #6f42c1;"></i>
                        <h5 style="color: #6f42c1; font-weight: bold;">Horario de Clases</h5>
                        <p class="small text-muted">Consulta tus materias y salones.</p>
                        <button class="btn btn-estudiante-solido btn-sm mt-auto w-100">Ver Horario</button>
                    </div>
                </div>

                <div class="col-md-4 mb-4">
                    <div class="card p-4 text-center border-0 shadow-sm h-100 card-estudiante-limpia"
                         style="border-top: 4px solid #6f42c1 !important; cursor: pointer;"
                         onclick="location.href='@Url.Action("MisNotas", "Estudiante")'">
                        <i class="bi bi-file-earmark-bar-graph fs-2 mb-2" style="color: #6f42c1;"></i>
                        <h5 style="color: #6f42c1; font-weight: bold;">Mis Calificaciones</h5>
                        <p class="small text-muted">Consulta tu rendimiento académico.</p>
                        <button class="btn btn-estudiante-solido btn-sm mt-auto w-100">Ver Notas</button>
                    </div>
                </div>

                <div class="col-md-4 mb-4">
                    <div class="card p-4 text-center border-0 shadow-sm h-100 card-estudiante-limpia"
                         style="border-top: 4px solid #6f42c1 !important; cursor: pointer;"
                         onclick="verActividadesEstudiante()">
                        <i class="bi bi-list-task fs-2 mb-2" style="color: #6f42c1;"></i>
                        <h5 style="color: #6f42c1; font-weight: bold;">Actividades</h5>
                        <p class="small text-muted">Tareas y trabajos pendientes.</p>
                        <button class="btn btn-estudiante-solido btn-sm mt-auto w-100">Ver Tareas</button>
                    </div>
                </div>

                <div class="col-md-4 mb-4">
                    <div class="card p-4 text-center border-0 shadow-sm h-100 card-estudiante-limpia"
                         style="border-top: 4px solid #6f42c1 !important; cursor: pointer;"
                         onclick="verCursosExtra()">
                        <i class="bi bi-stars fs-2 mb-2" style="color: #6f42c1;"></i>
                        <h5 style="color: #6f42c1; font-weight: bold;">Cursos Extracurriculares</h5>
                        <p class="small text-muted">Actividades y talleres adicionales.</p>
                        <button class="btn btn-estudiante-solido btn-sm mt-auto w-100">Ver Cursos</button>
                    </div>
                </div>

            </div>
