@{
    ViewData["Title"] = "Portal de Autogestión Educativa";
}

<div class="container-fluid py-5" style="background-color: #0d2a4a; border-radius: 0 0 50px 50px;">
    <div class="container py-5">
        <div class="row align-items-center">
            <div class="col-lg-6 text-white">
                <h1 class="display-3 fw-bold mb-4">Optimiza la Gestión de tu Institución</h1>
                <p class="lead mb-5 opacity-75">Centralice información académica, administrativa y docente en una sola plataforma segura e intuitiva. Diseñado para el sector educativo privado.</p>
                <div class="d-flex gap-3">
                    <a asp-action="Cursos" class="btn btn-lg px-4 text-white" style="background-color: #e67e22; border-radius: 12px;">Ver Módulos</a>
                    <a asp-action="Contacto" class="btn btn-lg btn-outline-light px-4" style="border-radius: 12px;">Solicitar Demo</a>
                </div>
            </div>
            <div class="col-lg-6 text-center mt-5 mt-lg-0">
                <img src="~/images/logo.png" alt="PAE System" class="img-fluid" style="max-height: 400px; filter: drop-shadow(0 0 20px rgba(255,255,255,0.2));">
            </div>
        </div>
    </div>
</div>

<div class="container my-5 py-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold" style="color: #0d2a4a;">¿Por qué elegir PAE?</h2>
        <p class="text-muted">La solución integral para la educación básica y media.</p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="p-4 text-center">
                <div class="bg-light rounded-circle d-inline-flex p-3 mb-3">
                    <i class="bi bi-cloud-check fs-1 text-primary"></i>
                </div>
                <h5>Información Centralizada</h5>
                <p class="small text-muted">Acceda a datos de estudiantes, docentes y calificaciones desde cualquier lugar y dispositivo.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 text-center">
                <div class="bg-light rounded-circle d-inline-flex p-3 mb-3">
                    <i class="bi bi-shield-lock fs-1 text-success"></i>
                </div>
                <h5>Seguridad y Privacidad</h5>
                <p class="small text-muted">Protegemos la información sensible de la comunidad educativa con los más altos estándares.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 text-center">
                <div class="bg-light rounded-circle d-inline-flex p-3 mb-3">
                    <i class="bi bi-chat-dots fs-1 text-warning"></i>
                </div>
                <h5>Mejor Comunicación</h5>
                <p class="small text-muted">Facilite el contacto entre padres, docentes y administrativos de forma ágil.</p>
            </div>
        </div>
    </div>
</div>
