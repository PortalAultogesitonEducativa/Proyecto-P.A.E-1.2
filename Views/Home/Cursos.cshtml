@{
    ViewData["Title"] = "Funcionalidades del Sistema";
}

<div class="container my-5 text-center">
    <h1 class="fw-bold mb-2" style="color: #0d2a4a;">Gestión Académica Integral</h1>
    <p class="text-muted mb-5">Centralizamos la información para optimizar los procesos de su institución.</p>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <i class="bi bi-mortarboard-fill display-4 text-warning mb-3"></i>
                    <h5 class="fw-bold">Gestión Académica</h5>
                    <p class="small text-muted">Administración de matrículas, calificaciones, boletines digitales y seguimiento de asistencia por estudiante.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <i class="bi bi-person-workspace display-4 text-primary mb-3"></i>
                    <h5 class="fw-bold">Portal Docente</h5>
                    <p class="small text-muted">Herramientas para la carga de notas, planeación de clases y comunicación directa con padres de familia.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <i class="bi bi-gear-fill display-4 text-secondary mb-3"></i>
                    <h5 class="fw-bold">Gestión Operativa</h5>
                    <p class="small text-muted">Optimización de procesos administrativos, reportes institucionales y centralización de bases de datos.</p>
                </div>
            </div>
        </div>
    </div>
</div>
