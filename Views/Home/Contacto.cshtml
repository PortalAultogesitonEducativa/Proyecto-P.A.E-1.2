@{
    ViewData["Title"] = "Solicite una Demo";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center mb-5">
            <h2 class="fw-bold">¿Listo para modernizar su institución?</h2>
            <p class="text-muted">Déjenos sus datos y un asesor se pondrá en contacto para una demostración personalizada del sistema PAE.</p>
        </div>
        <div class="col-md-6 border p-4 rounded shadow-sm">
            <form>
                <div class="mb-3">
                    <label class="form-label">Institución Educativa</label>
                    <input type="text" class="form-control" placeholder="Nombre del colegio">
                </div>
                <div class="mb-3">
                    <label class="form-label">Correo Institucional</label>
                    <input type="email" class="form-control" placeholder="ejemplo@colegio.edu.co">
                </div>
                <div class="mb-3">
                    <label class="form-label">Mensaje</label>
                    <textarea class="form-control" rows="3" placeholder="¿Cuántos estudiantes maneja su institución?"></textarea>
                </div>
                <button type="submit" class="btn w-100 text-white fw-bold" style="background-color: #e67e22;">Enviar Solicitud</button>
            </form>
        </div>
    </div>
</div>
