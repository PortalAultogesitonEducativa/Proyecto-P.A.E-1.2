@model IEnumerable<dynamic>

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="bi bi-file-earmark-bar-graph me-2"></i>Reporte de Calificaciones</h4>
            <button onclick="window.print()" class="btn btn-sm btn-light">
                <i class="bi bi-printer me-1"></i> Imprimir PDF
            </button>
        </div>
        <div class="card-body">
            
            <div class="row mb-5 justify-content-center">
                <div class="col-md-8">
                    <canvas id="graficaNotas" style="max-height: 300px;"></canvas>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Estudiante</th>
                            <th>Materia</th>
                            <th>Periodo</th>
                            <th class="text-center">Nota Final</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.NombreEstudiante</td>
                                <td><span class="badge bg-secondary">@item.Materia</span></td>
                                <td>@item.Periodo °</td>
                                <td class="text-center fw-bold">@Convert.ToDouble(item.Nota).ToString("F1")</td>
                                <td>
                                    @if (Convert.ToDouble(item.Nota) >= 3.0)
                                    {
                                        <span class="text-success"><i class="bi bi-check-circle-fill me-1"></i> Aprobado</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger"><i class="bi bi-x-circle-fill me-1"></i> Reprobado</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const ctx = document.getElementById('graficaNotas');
    
    // Extraemos los datos de C# a JavaScript
    const colores = notas.map(n => n >= 3.0 ? 'rgba(39, 174, 96, 0.5)' : 'rgba(231, 76, 60, 0.5)');
    const bordes = notas.map(n => n >= 3.0 ? 'rgba(39, 174, 96, 1)' : 'rgba(231, 76, 60, 1)');

    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: nombres,
            datasets: [{
                label: 'Calificación Final',
                data: notas,
                backgroundColor: 'rgba(39, 174, 96, 0.5)',
                borderColor: 'rgba(39, 174, 96, 1)',
                borderWidth: 1
            }]
        },
        options: {
            scales: {
                y: { beginAtZero: true, max: 5 }
            }
        }
    });
</script>